# HuntBoard Environment Variables

# Database Configuration (used by docker-compose)
# For local development with Docker, these are set in docker-compose.yml
# DATABASE_URL=postgresql://huntboard:huntboard_dev_password@db:5432/huntboard

# Anthropic API Key for AI job scoring
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Nightly sync schedule (24-hour format, default: 3 AM)
NIGHTLY_SYNC_HOUR=3

# Enable/disable nightly sync (default: true)
NIGHTLY_SYNC_ENABLED=true

# SerpAPI Key for Google Jobs scraping (optional fallback)
# Get your key at: https://serpapi.com/
# SERPAPI_KEY=your_key_here

# AWS S3 Configuration for Resume Storage
# Create an S3 bucket and IAM user with read/write access
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_RESUME_BUCKET=huntboard-resumes-prod

# Local Storage Fallback (for development without AWS)
# Set to true to store resumes locally instead of S3
USE_LOCAL_STORAGE=false
