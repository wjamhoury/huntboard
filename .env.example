# HuntBoard Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# REQUIRED FOR LOCAL DEVELOPMENT
# =============================================================================

# Anthropic API Key for AI job scoring
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# =============================================================================
# OPTIONAL - LOCAL DEVELOPMENT
# =============================================================================

# Database (set automatically by docker-compose, override if needed)
# DATABASE_URL=postgresql://huntboard:huntboard_dev_password@db:5432/huntboard

# Auth bypass for local development (set to true by default in docker-compose)
# AUTH_DEV_MODE=true

# Resume storage - use local filesystem instead of S3
# Set to true for local development without AWS credentials
USE_LOCAL_STORAGE=true

# =============================================================================
# AWS CONFIGURATION (PRODUCTION)
# =============================================================================

# AWS credentials for S3 resume storage
# Create an S3 bucket and IAM user with read/write access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 bucket for resume storage
S3_RESUME_BUCKET=huntboard-resumes-prod

# =============================================================================
# COGNITO AUTHENTICATION (PRODUCTION)
# =============================================================================

# Cognito User Pool ID
COGNITO_USER_POOL_ID=us-east-1_H05jUkMV7

# Cognito App Client ID
COGNITO_APP_CLIENT_ID=5gmo5ojqegpnqqi28cnml0o2fb

# =============================================================================
# SCHEDULER CONFIGURATION
# =============================================================================

# Nightly sync schedule (24-hour format UTC, default: 3 AM)
NIGHTLY_SYNC_HOUR=3

# Enable/disable nightly sync (default: true)
NIGHTLY_SYNC_ENABLED=true

# =============================================================================
# EMAIL DIGESTS
# =============================================================================

# Set to "true" to log emails instead of sending via SES (default: true)
# Set to "false" to enable real email sending (requires SES setup)
DRY_RUN_EMAIL=true

# Secret for signing email unsubscribe tokens
JWT_SECRET=change-this-to-a-random-string

# Frontend URL for email links
FRONTEND_URL=https://huntboard.app

# =============================================================================
# ERROR MONITORING (OPTIONAL)
# =============================================================================

# Sentry DSN for backend error monitoring
# Get your DSN at: https://sentry.io/
SENTRY_DSN=

# Environment name for Sentry (e.g., "development", "staging", "production")
ENVIRONMENT=development

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# SerpAPI Key for Google Jobs scraping (optional fallback)
# Get your key at: https://serpapi.com/
# SERPAPI_KEY=

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# Note: These are configured in frontend/.env for local dev
# and frontend/.env.production for production builds
# =============================================================================
#
# VITE_API_URL=http://localhost:8000/api/v1
# VITE_AUTH_DEV_MODE=true
# VITE_COGNITO_USER_POOL_ID=us-east-1_H05jUkMV7
# VITE_COGNITO_CLIENT_ID=5gmo5ojqegpnqqi28cnml0o2fb
# VITE_COGNITO_DOMAIN=huntboard.auth.us-east-1.amazoncognito.com
# VITE_SENTRY_DSN=
